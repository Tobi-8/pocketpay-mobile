{
  "expo": {
    "name": "stellar-pocketpay-mobile",
    "slug": "stellar-pocketpay-mobile",
    "version": "1.0.0",
    "scheme": "stellar-pocketpay",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "PocketPay uses Face ID to lock and protect your wallet."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-router",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "PocketPay uses Face ID to lock and protect your wallet."
        }
      ]
    ]
  }
}
